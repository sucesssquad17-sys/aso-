rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInAs(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function protectedServerOwnedFields() {
      return [
        'billingProvider',
        'billingEmail',
        'dodoCustomerId',
        'dodoSubscriptionId',
        'dodoProductId',
        'subscriptionTier',
        'subscriptionInterval',
        'isPremium',
        'paypalSubscriptionId',
        'paypalPlanId',
        'subscriptionStatus',
        'pendingPlanId',
        'pendingInterval',
        'subscriptionCurrentPeriodEnd',
        'subscriptionCancelAtPeriodEnd',
        'subscriptionUpdatedAt',
        'competitorAsoLatestSnapshots'
      ];
    }

    function createDoesNotSetServerOwnedFields() {
      return !request.resource.data.keys().hasAny(protectedServerOwnedFields());
    }

    function updateDoesNotChangeServerOwnedFields() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(protectedServerOwnedFields());
    }

    // Deny everything by default. Allowed paths are declared explicitly below.
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // The main user doc contains editable workspace data plus server-owned billing state.
      allow read: if isSignedInAs(userId);
      allow create: if isSignedInAs(userId) && createDoesNotSetServerOwnedFields();
      allow update: if isSignedInAs(userId) && updateDoesNotChangeServerOwnedFields();
      // Account deletion goes through the server so billing/audit state can be retained safely.
      allow delete: if false;

      match /alert_events/{eventId} {
        // Alert events are created by the server-side rule engine.
        allow read: if isSignedInAs(userId);
        allow write: if false;
      }

      match /competitor_aso_diffs/{diffId} {
        // Competitor ASO diffs are generated by the server comparison pipeline.
        allow read: if isSignedInAs(userId);
        allow write: if false;
      }

      match /rank_history/{entryId} {
        // Archived keyword history is server-generated and owner-readable.
        allow read: if isSignedInAs(userId);
        allow write: if false;
      }

      match /competitor_rank_history/{entryId} {
        // Archived competitor history is server-generated and owner-readable.
        allow read: if isSignedInAs(userId);
        allow write: if false;
      }

      match /push_tokens/{tokenId} {
        // Push tokens are registered only through the authenticated server endpoint.
        allow read, write: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
