# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SENTRY_DSN: Optional. Sentry DSN for error tracking.
VITE_SENTRY_DSN=

# VITE_DODO_ENVIRONMENT: Optional. Expose the Dodo environment to the frontend if you need
# billing UI labels or environment-specific behavior. Typical values: "test" or "live".
VITE_DODO_ENVIRONMENT=

# VITE_FIREBASE_VAPID_KEY: Required for Firebase web push token generation.
# Get this from Firebase Console -> Project settings -> Cloud Messaging -> Web configuration.
VITE_FIREBASE_VAPID_KEY=

# FIREBASE_SERVICE_ACCOUNT_JSON: Optional but recommended for automatic server-side
# tracking. Paste the full Firebase service account JSON as a single-line string.
# Alternative: use GOOGLE_APPLICATION_CREDENTIALS to point at a service-account file.
FIREBASE_SERVICE_ACCOUNT_JSON=

# GOOGLE_APPLICATION_CREDENTIALS: Optional alternative to FIREBASE_SERVICE_ACCOUNT_JSON.
# Example:
# GOOGLE_APPLICATION_CREDENTIALS="C:\\path\\to\\service-account.json"
GOOGLE_APPLICATION_CREDENTIALS=

# CRON_SECRET: Required to authorize external calls to /api/cron/run.
CRON_SECRET=

# DODO_API_KEY: Server-side Dodo Payments API key.
# Alias supported by the server: DODO_PAYMENTS_API_KEY
DODO_API_KEY=

# DODO_WEBHOOK_SECRET: Secret used to validate Dodo webhook signatures.
# Alias supported by the server: DODO_PAYMENTS_WEBHOOK_KEY
DODO_WEBHOOK_SECRET=

# DODO_PRODUCT_ID / DODO_PRICE_ID: Defaults for the primary paid plan.
# The current checkout integration uses DODO_PRODUCT_ID as the fallback Starter plan.
DODO_PRODUCT_ID=
DODO_PRICE_ID=

# Optional plan-specific monthly product IDs for the authenticated paywall.
DODO_PRODUCT_ID_INDIE=
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PRO=

# Optional yearly subscription product IDs for the authenticated paywall.
DODO_PRODUCT_ID_INDIE_YEARLY=
DODO_PRODUCT_ID_STARTER_YEARLY=
DODO_PRODUCT_ID_PRO_YEARLY=

# DODO_ENVIRONMENT: Optional. Supported values: "test", "live", "test_mode", "live_mode".
DODO_ENVIRONMENT=test

# Configure this webhook in Dodo Dashboard -> Developers -> Webhooks
# Endpoint: https://your-app.example.com/api/dodo/webhook
