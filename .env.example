# Public app URL used for billing return URLs, alert emails, and server links.
APP_URL=

# Frontend Firebase client config. These are required for the web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# Optional web push config. Required only if you want browser push alerts.
VITE_FIREBASE_VAPID_KEY=

# Optional frontend telemetry / UI config.
VITE_SENTRY_DSN=
VITE_DODO_ENVIRONMENT=

# Gemini powers keyword discovery and analysis fallbacks on the server.
GEMINI_API_KEY=

# Firebase Admin credentials for the Express server and daily tracking job.
# Use either FIREBASE_SERVICE_ACCOUNT_JSON or GOOGLE_APPLICATION_CREDENTIALS.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Required for protected manual cron endpoints.
CRON_SECRET=

# Optional residential proxy used for Google Play / App Store fallbacks.
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional Resend configuration for rule-based email alerts.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Dodo Payments server config.
# Aliases also supported: DODO_PAYMENTS_API_KEY, DODO_PAYMENTS_WEBHOOK_KEY.
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_ID=
DODO_PRICE_ID=

# Optional plan product IDs used by the upgrade flow.
DODO_PRODUCT_ID_INDIE=
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_PRO=
DODO_PRODUCT_ID_INDIE_YEARLY=
DODO_PRODUCT_ID_STARTER_YEARLY=
DODO_PRODUCT_ID_PRO_YEARLY=

# Supported values: test, live, test_mode, live_mode.
DODO_ENVIRONMENT=test
