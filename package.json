{
  "name": "rank-analyzer-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:job": "esbuild scripts/run-daily-tracking.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/tracking-job.cjs",
    "build:all": "npm run build && npm run build:job",
    "metrics:evaluate": "tsx scripts/evaluate-keyword-metrics.ts",
    "tracking:daily": "tsx scripts/run-daily-tracking.ts",
    "backfill:tracking-schedules": "tsx scripts/backfill-enable-tracking-schedules.ts",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test:backend-email": "node --import tsx --test tests/backend-email.test.ts",
    "test:tracking-schedule": "node --import tsx --test tests/tracking-schedule.test.ts",
    "lint": "tsc --noEmit",
    "lint:strict": "tsc -p tsconfig.strict.json --noEmit",
    "check:tracking-timezone": "tsx scripts/check-tracking-timezone.ts",
    "deploy:hosting": "npm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@sentry/browser": "^10.47.0",
    "@sentry/react": "^10.47.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "acorn-loose": "^8.5.2",
    "app-store-scraper": "^0.18.0",
    "clsx": "^2.1.1",
    "dodopayments": "^2.38.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.10.0",
    "google-play-scraper": "^10.1.2",
    "html2canvas": "^1.4.1",
    "https-proxy-agent": "^9.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cache": "^5.1.2",
    "openai": "^4.104.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "resend": "^6.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cache": "^4.1.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
